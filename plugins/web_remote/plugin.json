{
  "id": "mediahub.web_remote",
  "name": "MediaHub WebRemote",
  "version": "0.13.7",
  "author": "Master0701",
  "description": "Lokales MediaHub Desktop-Control-Center für PC und Notebook mit vollständigem Web-Assistenten und Live-Downloads.",
  "type": "web",
  "enabled": true,
  "entry": "plugin.py",
  "icon": "",
  "safe_mode": true,
  "minimum_mediahub_version": "1.0.5",
  "shared_runtime": "mediahub_web_core",
  "network_scope": "configurable_desktop",
  "class_name": "MediaHubWebRemotePlugin",
  "permissions": [
    "read_status",
    "read_dashboard",
    "read_channels",
    "read_playlists",
    "read_library",
    "read_downloads",
    "read_jobs",
    "read_scheduler",
    "read_statistics",
    "read_plugins",
    "read_system",
    "read_activities",
    "actions.setup_wizard.open",
    "actions.channels.sync",
    "actions.downloads.control",
    "actions.jobs.control",
    "actions.scheduler.control",
    "actions.plugins.open",
    "read_setup_wizard",
    "actions.setup_wizard.control",
    "network.home",
    "actions.plugins.control",
    "actions.plugins.manage"
  ],
  "minimum_mediahub": "1.0.5",
  "has_settings": true,
  "ui": {
    "enabled": true,
    "type": "web",
    "title": "MediaHub WebRemote",
    "web": {
      "enabled": true,
      "title": "MediaHub WebRemote",
      "route": "/",
      "icon": "🌐",
      "shell": true
    },
    "route": "/"
  }
}
