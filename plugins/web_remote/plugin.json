{
  "id": "mediahub.web_remote",
  "name": "MediaHub WebRemote",
  "version": "0.5.3",
  "author": "Master0701",
  "description": "Lokales MediaHub Control Center für MediaHub v1.0.5 mit Live-Dashboard, Kanalansicht, Downloads, Warteschlange und beobachteten Live-Aktivitäten.",
  "type": "web",
  "enabled": true,
  "entry": "plugin.py",
  "icon": "",
  "safe_mode": true,
  "minimum_mediahub_version": "1.0.5",
  "shared_runtime": "mediahub_web_core",
  "network_scope": "computer_only",
  "class_name": "MediaHubWebRemotePlugin",
  "permissions": [
    "read_status",
    "read_counts",
    "read_channels",
    "read_downloads",
    "read_activities"
  ],
  "minimum_mediahub": "1.0.5"
}
