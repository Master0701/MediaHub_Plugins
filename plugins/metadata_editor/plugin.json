{
  "id": "mediahub.metadata_editor",
  "name": "MediaHub Metadata Editor",
  "version": "0.3.6",
  "author": "Master0701",
  "description": "Zentraler lokaler Medienbrowser mit Metadaten-, NFO- und Bildeditor, Live-Vergleich und automatischen Sicherungen.",
  "type": "tool",
  "enabled": true,
  "entry": "plugin.py",
  "icon": "",
  "safe_mode": true,
  "minimum_mediahub_version": "1.0.5",
  "minimum_mediahub": "1.0.5",
  "shared_runtime": "mediahub_web_core",
  "network_scope": "local_only",
  "class_name": "MediaHubMetadataEditorPlugin",
  "permissions": [
    "read_library",
    "read_channels",
    "read_playlists",
    "read_metadata",
    "write_metadata_drafts",
    "actions.metadata.update",
    "network.local",
    "read_local_metadata_files",
    "write_nfo_files",
    "write_local_images",
    "create_metadata_backups"
  ],
  "has_settings": false,
  "ui": {
    "enabled": true,
    "type": "window",
    "title": "Metadata Editor",
    "icon": "📝",
    "order": 30,
    "web": {
      "enabled": true,
      "title": "Metadata Editor",
      "route": "/metadata-editor",
      "icon": "📝",
      "order": 30,
      "shell": false
    }
  }
}
