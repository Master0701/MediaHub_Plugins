{
  "schema_version": 1,
  "id": "mediahub_webremote",
  "name": "MediaHub WebRemote",
  "version": "0.3.0",
  "author": "Master0701",
  "description": "Lokale Weboberfläche zur Fernsteuerung von MediaHub im Heimnetz.",
  "type": "web",
  "entry": "main.py",
  "minimum_mediahub": "1.0.3",
  "platforms": [
    "windows"
  ],
  "permissions": [
    "local_network",
    "mediahub_api"
  ],
  "package_format": "mhplugin",
  "enabled": true
}
